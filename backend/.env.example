# --- App ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-secret
FRONTEND_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://prescription_app:changeme@localhost:5432/prescription_mgmt
TEST_DATABASE_URL=postgresql+asyncpg://prescription_app:changeme@localhost:5432/prescription_mgmt_test

# --- Email verification ---
EMAIL_VERIFICATION_OTP_EXPIRE_MINUTES=10
EMAIL_VERIFICATION_OTP_MAX_ATTEMPTS=5

# --- Sessions / cookies ---
ACCESS_TOKEN_EXPIRE_DAYS=7
ACCESS_TOKEN_REMEMBER_ME_EXPIRE_DAYS=30
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Password reset ---
PASSWORD_RESET_OTP_EXPIRE_MINUTES=10
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5

# --- SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true
